{
  "name": "docs-server",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "node scripts/prepare-build.cjs",
    "build:no-check": "cross-env BUILD_NO_CHECK=1 node scripts/prepare-build.cjs",
    "start": "NODE_ENV=production node build/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
